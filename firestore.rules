rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Categories and questions are public read-only reference data — no user
    // data lives here yet. Writes only happen from the seed script (admin
    // credentials) or, later, Cloud Functions — never from the client.
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false;
    }
    match /questions/{questionId} {
      allow read: if true;
      allow write: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
