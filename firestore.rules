rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Categories and questions are public read-only reference data — no user
    // data lives here yet. Writes only happen from the seed script (admin
    // credentials) or, later, Cloud Functions — never from the client.
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false;
    }
    match /questions/{questionId} {
      allow read: if true;
      allow write: if false;
    }

    // `answers/{questionId}` (correctIndex) and everything else is denied by
    // this catch-all — clients never see correct answers, by construction.
    // Only admin-credentialed scripts (seed.js) or, later, Cloud Functions
    // can read/write it.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
